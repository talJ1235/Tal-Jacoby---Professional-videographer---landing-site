# Client env template. Copy to client/.env for local dev (client/.env is gitignored).
# VITE_* vars are exposed to the browser bundle. Everything else is server-side only
# (read by the /api serverless functions and the local dev-api shim).

# ── Client (browser) ────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3001      # local API origin; leave empty in prod
VITE_WHATSAPP_NUMBER=972XXXXXXXXX
VITE_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Content publishing (SERVER-SIDE ONLY — never prefix with VITE_) ──────────
# Set these in the Vercel dashboard (Production, Preview, Development) too.
GITHUB_TOKEN=github_pat_CHANGE_ME          # fine-grained PAT, contents:read+write
GITHUB_REPO=owner/repo-name                # e.g. talJ1235/Tal-Jacoby---...
GITHUB_BRANCH=main                         # deploy branch Vercel watches
ADMIN_SECRET=CHANGE_ME_STRONG_SECRET       # reused for admin + content auth
